# Migrate to Linux -- saved answers for execute_all.sh
# Edit these values, or delete this file to be asked each question interactively.
# Yes/No = y/n ; VERSION_MODE = same|latest ; BEST_ALTERNATIVES = a whole number.
INSTALL_DRIVERS=y
INSTALL_APPS=y
BEST_ALTERNATIVES=1
VERSION_MODE=same
UPDATE_EXISTING=y
INSTALL_SECURITY=n
FREE_ONLY=n
APPLY_SETTINGS=y
REBUILD_DOCKER=y
