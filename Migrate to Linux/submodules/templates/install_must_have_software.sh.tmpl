#!/usr/bin/env bash
# =============================================================================
#  install_must_have_software.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Universal installer: detects the Linux distribution family (apt/dnf/zypper/
#  pacman) and CPU architecture at runtime, then installs each app Flatpak-first
#  with a native-package fallback.  Runs unchanged on every supported distro.
# =============================================================================
### __COMMON__ ###

main() {
  is_dry_run || require_root
  detect_distro
  detect_arch
  MODULE="Applications"
  log "Migrate to Linux  --  Must-Have Software"
  is_dry_run && log "DRY-RUN (report only): no changes will be made."
  info "Distribution : ${DISTRO_NAME}"
  info "Family / pm  : ${FAMILY} / ${PM}"
  info "Architecture : ${ARCH}"
  if ! is_dry_run; then
    pm_refresh
    ensure_flatpak || warn "Flatpak unavailable -- Flatpak-only apps will be skipped."
  fi

  # ---------------------------------------------------------------------------
  # Application install list (generated from B_applications.json + the
  # Additional_Manual_Linux_Software_Requirments.csv).
  # ---------------------------------------------------------------------------
  ### __APPS_DATA__ ###

  print_summary
}

main "$@"
