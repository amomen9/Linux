# =============================================================================
#  execute_all.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Orchestrator: runs the three generated scripts in order on the current distro.
#    1. install_device_drivers.sh
#    2. install_must_have_software.sh
#    3. apply_settings.sh
#  Usage:  sudo ./execute_all.sh
# =============================================================================
### __COMMON__ ###

main() {
  require_root
  detect_distro
  detect_arch
  log "Migrate to Linux  --  Run All"
  info "Distribution : ${DISTRO_NAME}"
  info "Family / pm  : ${FAMILY} / ${PM}"
  info "Architecture : ${ARCH}"

  local here; here="$(cd "$(dirname "$0")" && pwd)"
  local step
  for step in install_device_drivers.sh install_must_have_software.sh apply_settings.sh; do
    if [ -f "$here/$step" ]; then
      log "=== Running $step ==="
      bash "$here/$step" || warn "$step reported errors (continuing)"
    else
      warn "missing: $step"
    fi
  done

  # Optional Docker rebuild. docker_rebuild.sh is only present when Docker was
  # installed on the Windows source (docker_discovery created it), so the prompt
  # is only shown in that case.
  if [ -f "$here/docker_rebuild.sh" ]; then
    printf '\n'
    local ans=""
    read -r -p "Rebuild docker components? (y/n): " ans </dev/tty 2>/dev/null || ans="n"
    case "$ans" in
      [Yy]*) log "=== Running docker_rebuild.sh ==="
             bash "$here/docker_rebuild.sh" || warn "docker_rebuild.sh reported errors" ;;
      *)     info "Skipping docker rebuild." ;;
    esac
  fi

  log "All steps finished."
  info "Per-step logs are under /tmp/migrate_to_linux_results.tsv (last step wins)."
}

main "$@"
