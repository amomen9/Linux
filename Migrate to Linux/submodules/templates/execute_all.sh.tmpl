#!/usr/bin/env bash
# =============================================================================
#  execute_all.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Single entry point. Asks the stage questions UP FRONT (each question and its
#  options are shown), runs the chosen stages UNATTENDED:
#    drivers -> must-have software -> settings -> (optional) docker rebuild
#  and finally handles MANUAL DOWNLOADS last (place each file, then 'done'/'skip').
#  Usage:  sudo ./execute_all.sh
# =============================================================================
### __COMMON__ ###

# Manual-download apps with no automatic installer (format: "Windows app|hint").
# Handled at the very END so they never block the unattended stages.
MANUAL_APPS=(
### __MANUAL_APPS__ ###
)

here=""

# Yes/No question. The question text AND (y/n) are always printed to the terminal.
ask() {  # ask "Question text" [default y|n]   -> 0 = yes, 1 = no
  local q="$1" def="${2:-y}" ans
  if [ ! -r /dev/tty ]; then case "$def" in [Yy]*) return 0 ;; *) return 1 ;; esac; fi
  while :; do
    printf '  %s (y/n): ' "$q" > /dev/tty
    if ! read -r ans < /dev/tty; then case "$def" in [Yy]*) return 0 ;; *) return 1 ;; esac; fi
    case "$ans" in
      [Yy]|[Yy][Ee][Ss]) return 0 ;;
      [Nn]|[Nn][Oo])     return 1 ;;
      *) printf '\033[1;31m  Please answer y or n.\033[0m\n' > /dev/tty ;;
    esac
  done
}

run_stage() {  # run_stage script.sh
  local step="$1"
  if [ -f "$here/$step" ]; then
    log "=== Running $step ==="
    bash "$here/$step" || warn "$step reported errors (continuing)"
  else
    warn "missing: $step"
  fi
}

# Manual downloads, handled LAST. For each app: show what to download and where to
# put it, then ask (done/skip). On 'done', verify the file is present and install
# it; if it is missing/unusable, show a red error and ask again until the file is
# correctly placed or the user types 'skip'.
install_manual_apps() {
  [ "${#MANUAL_APPS[@]}" -eq 0 ] && return 0
  local base="${MIGRATE_MANUAL_DIR:-$DOWNLOAD_DIR/manual}"
  printf '\n'; log "Manual downloads (apps with no automatic installer) -- done last"
  local entry name hint slug dir ans f got
  for entry in "${MANUAL_APPS[@]}"; do
    name="${entry%%|*}"; hint="${entry#*|}"
    slug="$(slugify "$name")"; dir="$base/$slug"; mkdir -p "$dir"
    printf '\n'
    printf '\033[1;34m==> Manual install: %s\033[0m\n' "$name" >&3
    [ -n "$hint" ] && [ "$hint" != "$name" ] && info "$hint"
    info "Place the downloaded file into this folder, then type 'done':"
    info "    $dir"
    if [ ! -r /dev/tty ]; then mark_skip "$name" "no tty for manual prompt"; continue; fi
    while :; do
      printf '  %s (done/skip): ' "$name" > /dev/tty
      read -r ans < /dev/tty || ans="skip"
      case "$ans" in
        [Ss]|[Ss][Kk][Ii][Pp])
          mark_skip "$name" "user skipped"; break ;;
        [Dd]|[Dd][Oo][Nn][Ee])
          if [ -z "$(ls -A "$dir" 2>/dev/null)" ]; then
            printf '\033[1;31m  No file found in %s -- place the file there, then type done (or skip).\033[0m\n' "$dir" > /dev/tty
            continue
          fi
          got=0
          for f in "$dir"/*; do
            case "$f" in
              *.deb|*.rpm|*.pkg.tar.*|*.pkg.tar) if install_local_package "$f"; then got=1; fi ;;
              *) info "placed (run/extract manually): $f"; got=1 ;;
            esac
          done
          if [ "$got" -eq 1 ]; then
            mark_ok "$name" "installed/placed from $dir"; break
          else
            printf '\033[1;31m  Could not install the file(s) in %s -- fix the file, then type done (or skip).\033[0m\n' "$dir" > /dev/tty
          fi
          ;;
        *)
          printf '\033[1;31m  Please type "done" or "skip".\033[0m\n' > /dev/tty ;;
      esac
    done
  done
}

main() {
  require_root
  detect_distro
  detect_arch
  here="$(cd "$(dirname "$0")" && pwd)"

  log "Migrate to Linux  --  Run All"
  info "Distribution : ${DISTRO_NAME}"
  info "Family / pm  : ${FAMILY} / ${PM}"
  info "Architecture : ${ARCH}"

  # ---- Stage questions, up front (each question is shown with its options) ----
  log "Setup questions (answer each one; the install then runs unattended):"
  local do_drivers=0 do_apps=0 do_settings=0 do_docker=0
  ask "Install device drivers?"     y && do_drivers=1
  ask "Install must-have software?" y && do_apps=1
  ask "Apply Windows settings?"     y && do_settings=1
  if [ -f "$here/docker_rebuild.sh" ]; then
    ask "Rebuild docker components?" n && do_docker=1
  fi

  # ---- Run the selected stages, unattended ----
  [ "$do_drivers"  -eq 1 ] && run_stage install_device_drivers.sh
  [ "$do_apps"     -eq 1 ] && run_stage install_must_have_software.sh
  [ "$do_settings" -eq 1 ] && run_stage apply_settings.sh
  if [ "$do_docker" -eq 1 ]; then
    log "=== Running docker_rebuild.sh ==="
    bash "$here/docker_rebuild.sh" || warn "docker_rebuild.sh reported errors"
  fi

  # ---- Manual downloads LAST (only if the apps stage was selected) ----
  [ "$do_apps" -eq 1 ] && install_manual_apps

  printf '\n'; log "All steps finished."
  info "Per-step logs are under /tmp/migrate_to_linux_results.tsv (last step wins)."
}

main "$@"
