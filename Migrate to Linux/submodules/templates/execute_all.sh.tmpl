#!/usr/bin/env bash
# =============================================================================
#  execute_all.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Single entry point. Asks ALL interactive questions UP FRONT (which stages to
#  run, whether to rebuild Docker, and the file paths for manual-download apps),
#  then runs the chosen stages UNATTENDED:
#    drivers -> must-have software -> settings -> (optional) docker rebuild
#  Usage:  sudo ./execute_all.sh
# =============================================================================
### __COMMON__ ###

# Manual-install apps that need a file you download yourself. Collected up front
# (format: "Windows app|hint"); install_must_have_software.sh installs the staged
# file later via the matching slug.
MANUAL_APPS=(
### __MANUAL_APPS__ ###
)

here=""

# ask "Question" [default y|n]  ->  returns 0 for yes, 1 for no
ask() {
  local q="$1" def="${2:-y}" ans="" hint
  if [ "$def" = "y" ]; then hint="Y/n"; else hint="y/N"; fi
  read -r -p "  $q ($hint): " ans </dev/tty 2>/dev/null || ans="$def"
  [ -z "$ans" ] && ans="$def"
  case "$ans" in [Yy]*) return 0 ;; *) return 1 ;; esac
}

# Ask the user for each manual app's downloaded file and stage it for the installer.
collect_manual_files() {
  [ "${#MANUAL_APPS[@]}" -eq 0 ] && return 0
  local base="${MIGRATE_MANUAL_DIR:-$DOWNLOAD_DIR/manual}"
  mkdir -p "$base"
  log "A few apps need a file you download yourself. Give each path now, or press Enter to skip."
  local entry name hint slug path
  for entry in "${MANUAL_APPS[@]}"; do
    name="${entry%%|*}"; hint="${entry#*|}"
    slug="$(slugify "$name")"
    printf '\n'; info "$name"
    [ -n "$hint" ] && [ "$hint" != "$name" ] && info "  $hint"
    read -r -p "  Path to the downloaded file for '$name' (Enter to skip): " path </dev/tty 2>/dev/null || path=""
    if [ -n "$path" ] && [ -f "$path" ]; then
      if mkdir -p "$base/$slug" && cp -f "$path" "$base/$slug/"; then ok "staged: $name"; else warn "could not stage $name"; fi
    else
      info "skipping $name"
    fi
  done
  export MIGRATE_MANUAL_DIR="$base"
}

run_stage() {  # run_stage script.sh
  local step="$1"
  if [ -f "$here/$step" ]; then
    log "=== Running $step ==="
    bash "$here/$step" || warn "$step reported errors (continuing)"
  else
    warn "missing: $step"
  fi
}

main() {
  require_root
  detect_distro
  detect_arch
  here="$(cd "$(dirname "$0")" && pwd)"

  log "Migrate to Linux  --  Run All"
  info "Distribution : ${DISTRO_NAME}"
  info "Family / pm  : ${FAMILY} / ${PM}"
  info "Architecture : ${ARCH}"

  # ---- Ask everything up front; the run is unattended afterwards ----
  log "Setup questions (answer once -- the install then runs unattended):"
  local do_drivers=0 do_apps=0 do_settings=0 do_docker=0
  ask "Install device drivers?"        y && do_drivers=1
  ask "Install must-have software?"    y && do_apps=1
  ask "Apply Windows settings?"        y && do_settings=1
  if [ -f "$here/docker_rebuild.sh" ]; then
    ask "Rebuild docker components?"   n && do_docker=1
  fi
  if [ "$do_apps" -eq 1 ]; then collect_manual_files; fi

  # ---- Run the selected stages, unattended ----
  [ "$do_drivers"  -eq 1 ] && run_stage install_device_drivers.sh
  [ "$do_apps"     -eq 1 ] && run_stage install_must_have_software.sh
  [ "$do_settings" -eq 1 ] && run_stage apply_settings.sh
  if [ "$do_docker" -eq 1 ]; then
    log "=== Running docker_rebuild.sh ==="
    bash "$here/docker_rebuild.sh" || warn "docker_rebuild.sh reported errors"
  fi

  log "All steps finished."
  info "Per-step logs are under /tmp/migrate_to_linux_results.tsv (last step wins)."
}

main "$@"
