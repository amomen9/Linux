#!/usr/bin/env bash
# =============================================================================
#  install_device_drivers.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Device drivers on Linux are mostly in-kernel.  This script enables firmware,
#  installs GPU drivers (proprietary NVIDIA on demand), printer/scanner support,
#  and lists the Windows devices detected on the source machine for reference.
#  Best-effort and family-aware (apt/dnf/zypper/pacman).
# =============================================================================
### __COMMON__ ###

install_firmware() {
  log "Linux firmware"
  case "$PM" in
    apt)    pm_install linux-firmware ;;
    dnf)    pm_install linux-firmware ;;
    zypper) pm_install kernel-firmware ;;
    pacman) pm_install linux-firmware ;;
  esac && ok "firmware package installed" || warn "firmware package not installed"
}

install_gpu() {
  log "Graphics drivers"
  local gpu; gpu="$(lspci 2>/dev/null | grep -iE 'vga|3d|display' || true)"
  [ -n "$gpu" ] && info "$gpu"
  if printf '%s' "$gpu" | grep -qi nvidia; then
    warn "NVIDIA GPU detected."
    case "$PM" in
      apt)    have_cmd ubuntu-drivers && { ubuntu-drivers autoinstall && mark_ok "NVIDIA driver"; } \
                 || pm_install nvidia-driver && mark_ok "NVIDIA driver (nvidia-driver)" || mark_manual "NVIDIA driver" "apt: nvidia-driver-XXX" ;;
      dnf)    mark_manual "NVIDIA driver" "enable RPM Fusion, then: dnf install akmod-nvidia" ;;
      zypper) mark_manual "NVIDIA driver" "add the openSUSE NVIDIA repo, then install nvidia drivers" ;;
      pacman) pm_install nvidia nvidia-utils && mark_ok "NVIDIA driver" || mark_manual "NVIDIA driver" "pacman: nvidia / nvidia-lts" ;;
    esac
  elif printf '%s' "$gpu" | grep -qiE 'amd|radeon|ati'; then
    info "AMD GPU -> open-source amdgpu/radeon driver is in the kernel (Mesa)."
    pm_install mesa-utils 2>/dev/null || pm_install mesa-demos 2>/dev/null || true
  elif printf '%s' "$gpu" | grep -qi intel; then
    info "Intel GPU -> open-source driver is in the kernel (Mesa)."
  fi
}

install_printing() {
  log "Printer / scanner support"
  case "$PM" in
    apt)    pm_install cups system-config-printer sane-utils ;;
    dnf)    pm_install cups system-config-printer sane-backends ;;
    zypper) pm_install cups sane-backends ;;
    pacman) pm_install cups sane ;;
  esac && { systemctl enable --now cups 2>/dev/null; mark_ok "printing/scanning (CUPS+SANE)"; } \
       || mark_manual "printing" "install cups + sane for your distro"
}

list_source_drivers() {
  log "Windows devices detected on the source machine (reference only)"
  ### __DRIVERS_DATA__ ###
}

main() {
  require_root
  detect_distro
  detect_arch
  log "Migrate to Linux  --  Device Drivers"
  info "Distribution : ${DISTRO_NAME}"
  info "Family / pm  : ${FAMILY} / ${PM}"
  pm_refresh
  install_firmware
  install_gpu
  install_printing
  list_source_drivers
  print_summary
}

main "$@"
