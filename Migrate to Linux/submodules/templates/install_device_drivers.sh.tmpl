#!/usr/bin/env bash
# =============================================================================
#  install_device_drivers.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Device drivers on Linux are mostly in-kernel.  This script enables firmware,
#  installs GPU drivers (proprietary NVIDIA on demand), printer/scanner support,
#  and lists the Windows devices detected on the source machine for reference.
#  Best-effort and family-aware (apt/dnf/zypper/pacman).
# =============================================================================
### __COMMON__ ###

install_firmware() {
  log "Linux firmware"
  local pkg=linux-firmware
  [ "$PM" = "zypper" ] && pkg=kernel-firmware
  if capture pm_install "$pkg"; then ok "firmware package installed"
  else mark_fail "firmware ($pkg)" "${LAST_ERR:-could not install firmware package}"; fi
}

install_gpu() {
  log "Graphics drivers"
  local gpu; gpu="$(lspci 2>/dev/null | grep -iE 'vga|3d|display' || true)"
  [ -n "$gpu" ] && info "$gpu"
  if printf '%s' "$gpu" | grep -qi nvidia; then
    warn "NVIDIA GPU detected."
    case "$PM" in
      apt)
        if have_cmd ubuntu-drivers && capture ubuntu-drivers autoinstall; then mark_ok "NVIDIA driver"
        elif capture pm_install nvidia-driver; then mark_ok "NVIDIA driver (nvidia-driver)"
        else mark_fail "NVIDIA driver" "${LAST_ERR:-apt: try a specific nvidia-driver-XXX}"; fi ;;
      dnf)    mark_manual "NVIDIA driver" "enable RPM Fusion, then: dnf install akmod-nvidia" ;;
      zypper) mark_manual "NVIDIA driver" "add the openSUSE NVIDIA repo, then install nvidia drivers" ;;
      pacman)
        if capture pm_install nvidia nvidia-utils; then mark_ok "NVIDIA driver"
        else mark_fail "NVIDIA driver" "${LAST_ERR:-pacman: nvidia / nvidia-lts}"; fi ;;
    esac
  elif printf '%s' "$gpu" | grep -qiE 'amd|radeon|ati'; then
    info "AMD GPU -> open-source amdgpu/radeon driver is in the kernel (Mesa)."
    pm_install mesa-utils 2>/dev/null || pm_install mesa-demos 2>/dev/null || true
  elif printf '%s' "$gpu" | grep -qi intel; then
    info "Intel GPU -> open-source driver is in the kernel (Mesa)."
  fi
}

install_printing() {
  log "Printer / scanner support"
  local rc=0
  case "$PM" in
    apt)    capture pm_install cups system-config-printer sane-utils || rc=1 ;;
    dnf)    capture pm_install cups system-config-printer sane-backends || rc=1 ;;
    zypper) capture pm_install cups sane-backends || rc=1 ;;
    pacman) capture pm_install cups sane || rc=1 ;;
  esac
  if [ "$rc" -eq 0 ]; then systemctl enable --now cups 2>/dev/null; mark_ok "printing/scanning (CUPS+SANE)"
  else mark_fail "printing/scanning" "${LAST_ERR:-could not install cups + sane}"; fi
}

list_source_drivers() {
  log "Windows devices detected on the source machine (reference only)"
  ### __DRIVERS_DATA__ ###
}

main() {
  require_root
  detect_distro
  detect_arch
  log "Migrate to Linux  --  Device Drivers"
  info "Distribution : ${DISTRO_NAME}"
  info "Family / pm  : ${FAMILY} / ${PM}"
  pm_refresh
  install_firmware
  install_gpu
  install_printing
  list_source_drivers
  print_summary
}

main "$@"
