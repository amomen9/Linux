#!/usr/bin/env bash
# =============================================================================
#  restore_user_and_application_data.sh
#  GENERATED by submodules/D_compile_and_generate_shell_script.ps1 -- do not edit.
#
#  Step 6 (Linux side). Restores the password-protected archive built on Windows by
#  E_backup_user&application_data.ps1. Reads the classification manifest
#  (submodules/D_data_migration.json) and, per application scope, either:
#    * PROMOTES the data to its corresponding Linux path (linuxTarget), or
#    * places it in a DEVIATED/quarantine directory for the user to promote manually.
#  Decision table (see D_data_migration.json _decisionTable):
#    yes               -> promote
#    yes-after-rewrite -> rewrite text configs (+.bak) then promote
#    same version      -> promote IFF the (4/10) version answer was "same", else quarantine
#    no                -> quarantine
#  Nothing is altered destructively: rewrites are reversible (.bak) and the archive
#  itself is read-only input. The user is told to TEST each promoted app afterwards.
# =============================================================================
### __COMMON__ ###

selfdir="$(cd "$(dirname "$0")" && pwd)"
DM="$selfdir/D_data_migration.json"

# Resolve ~ / __TARGET_USER__ tokens in a manifest linuxTarget to a real path.
resolve_target() {  # resolve_target "~/.config/foo"
  local t="$1"
  t="${t//__TARGET_USER__/$TARGET_USER}"
  case "$t" in "~"/*) t="$TARGET_HOME/${t#\~/}" ;; "~") t="$TARGET_HOME" ;; esac
  printf '%s' "$t"
}

# Human-readable size from bytes (max 2 decimals).
hsize() {  # hsize BYTES
  awk -v b="$1" 'BEGIN{ s="B KB MB GB TB PB"; n=split(s,u," "); i=1;
    while(b>=1024 && i<n){b/=1024;i++} printf (b==int(b)?"%d %s":"%.2f %s"), b, u[i] }'
}

# Own a path for the target user, recursively (the script runs as root).
fix_owner() {  # fix_owner PATH
  [ -e "$1" ] || return 0
  chown -R "$TARGET_USER":"$TARGET_USER" "$1" 2>/dev/null || true
}

# Apply this scope's contentRewrites to text files under DIR (only used when promoting
# a "yes-after-rewrite" scope). Every edited file keeps a .bak (reversible).
apply_rewrites() {  # apply_rewrites APPKEY SCOPE DIR
  local appkey="$1" scope="$2" dir="$3" frx kind find repl bak f
  have_cmd jq || return 0
  jq -r --arg k "$appkey" --arg s "$scope" '
    (.applications[$k][$s].contentRewrites // [])[]
    | (.backup // true) as $b
    | .files[] as $f
    | .rules[] as $r
    | [$f, ($r.kind // "find"), ($r.find // ""), ($r.replace // ""), ($b|tostring)] | @tsv
  ' "$DM" 2>/dev/null | while IFS=$'\t' read -r frx kind find repl bak; do
    [ -z "$frx" ] && continue
    while IFS= read -r f; do
      [ -f "$f" ] || continue
      # text files only -- never touch binaries
      grep -Iq . "$f" 2>/dev/null || continue
      local bakflag=""; [ "$bak" = "true" ] && bakflag="-i.bak" || bakflag="-i"
      case "$kind" in
        winpath_to_linux)
          sed -E $bakflag 's@[A-Za-z]:[\\/]@/@g; s@\\@/@g' "$f" 2>/dev/null || true ;;
        userprofile_to_home)
          sed -E $bakflag "s@[A-Za-z]:[\\\\/]Users[\\\\/][^\\\\/\"']+@${TARGET_HOME}@g" "$f" 2>/dev/null || true ;;
        drive_map)
          sed -E $bakflag 's@[A-Za-z]:[\\/]@/@g' "$f" 2>/dev/null || true ;;
        find)
          [ -n "$find" ] && sed -E $bakflag "s@${find}@${repl}@g" "$f" 2>/dev/null || true ;;
      esac
    done < <(find "$dir" -type f 2>/dev/null | grep -E "$frx" 2>/dev/null || true)
  done
}

# Copy a staged tree into a destination, preserving structure, then fix ownership.
place_tree() {  # place_tree SRCDIR DESTDIR
  local src="$1" dst="$2"
  [ -d "$src" ] || return 0
  if is_dry_run; then info "[dry-run] would copy $src/* -> $dst"; return 0; fi
  mkdir -p "$dst" 2>/dev/null || true
  cp -a "$src/." "$dst/" 2>/dev/null || cp -r "$src/." "$dst/" 2>/dev/null || true
  fix_owner "$dst"
}

restore_main() {
  MODULE="User data"
  : "${MIGRATE_VERSION_MODE:=latest}"

  if [ ! -f "$DM" ]; then
    warn "No data-migration manifest ($DM) shipped with the installer -- skipping data restore."
    return 0
  fi
  if ! have_cmd jq; then
    ask_install_addition "data restore" "jq" "reading the data-migration manifest" || {
      warn "jq is unavailable -- cannot classify your data. Skipping data restore."
      return 0
    }
  fi

  log "Restore your backed-up user & application data (from Windows)"
  info "This restores the archive you created on Windows. Important user files land in your home"
  info "directory; application data either lands on its matching Linux path or, when that is not"
  info "safe, in a DEVIATED directory you choose, for you to promote by hand and TEST afterwards."

  # ---- Report list: where each thing is meant to go (<= 30 rows, else log-only) ----
  local logf="$TARGET_HOME/Desktop/migrate_to_linux_restore_plan.txt"
  mkdir -p "$(dirname "$logf")" 2>/dev/null || true
  : > "$logf" 2>/dev/null || logf="/tmp/migrate_to_linux_restore_plan.txt"
  local rows=() key scope tgt safe wine verb
  rows+=("your important profile files (Desktop/Documents/Pictures/...)  -->  your home (~/)")
  while IFS=$'\t' read -r key scope tgt safe wine; do
    [ -z "$key" ] && continue
    case "$safe" in
      yes|yes-after-rewrite) verb="corresponding path: $(resolve_target "$tgt")" ;;
      "same version")        verb="$([ "$MIGRATE_VERSION_MODE" = same ] && printf 'corresponding path: %s' "$(resolve_target "$tgt")" || printf 'DEVIATED dir (same-version not chosen)')" ;;
      *)                     verb="DEVIATED dir" ;;
    esac
    rows+=("$key [$scope]  -->  $verb")
  done < <(jq -r '
    .applications | to_entries[] | .key as $k | .value as $v
    | (["userdir","system"][]) as $s | select($v[$s] != null)
    | [ $k, $s,
        ($v[$s].linuxTarget // ""),
        ($v[$s].userdir_safe_to_transfer_to_corresponding_paths_for_linux // $v[$s].safe_to_transfer_to_corresponding_paths_for_linux // "no"),
        ($v.wine // false | tostring) ] | @tsv' "$DM" 2>/dev/null)
  printf '%s\n' "${rows[@]}" > "$logf" 2>/dev/null || true
  fix_owner "$logf"

  printf '\n' >&3
  if [ "${#rows[@]}" -le 30 ]; then
    local r; for r in "${rows[@]}"; do info "  $r"; done
  else
    warn "There are ${#rows[@]} items -- too many to list here. The full plan is in: $logf"
  fi

  # ---- Warnings (tone depends on whether decryption is possible) ----
  printf '\n' >&3
  warn "WARNING: depending on how much data you backed up, this can take a long time."
  warn "WARNING: this will probably NOT restore everything you might want. Continue only if you accept that risk."

  if [ ! -r /dev/tty ]; then
    info "Non-interactive: data restore is informational only here. Re-run interactively to restore. Plan: $logf"
    return 0
  fi

  # ---- Prompt 1: archive path ----
  printf '\n' >&3
  info "Enter the path to the backup archive you created on Windows (.tar.gz or .tar.gz.enc),"
  info "for example '${TARGET_HOME}/Downloads/MigrateToLinux_UserData_20260101_120000.tar.gz.enc'."
  local arch ans
  while :; do
    printf "  Data archive ('archive file path'/s=skip): " > /dev/tty
    read -r ans < /dev/tty || ans="skip"
    case "$ans" in
      [Ss]|[Ss][Kk][Ii][Pp]) info "Skipped restoring user & application data (it COULD have been transferred had you provided the archive). Plan: $logf"; return 0 ;;
      *) arch="$(resolve_user_path "$ans")"
         if [ -n "$arch" ] && [ -f "$arch" ] && [ -r "$arch" ]; then break; fi
         err "  No readable file at that path -- type the path in single quotes, or 's' to skip." ;;
    esac
  done

  # ---- Detect encryption + tools ----
  local magic encrypted=0
  magic="$(head -c 8 "$arch" 2>/dev/null)"
  [ "$magic" = "Salted__" ] && encrypted=1
  if [ "$encrypted" = 1 ]; then
    if ! have_cmd openssl; then
      ask_install_addition "data restore" "openssl" "decrypting your backup archive" || { warn "openssl unavailable -- cannot decrypt. Skipping."; return 0; }
    fi
    if [ -z "${MIGRATE_XFER_PWD:-}" ]; then
      warn "This archive is encrypted but no password was provided. It COULD be restored if you re-run and supply the password. Skipping."
      return 0
    fi
  fi

  # ---- Size + storage precheck ----
  local arch_bytes est_bytes free_bytes
  arch_bytes="$(stat -c %s "$arch" 2>/dev/null || echo 0)"
  est_bytes=$(awk -v a="$arch_bytes" 'BEGIN{printf "%d", a/0.6}')   # rough inflate from medium gzip
  free_bytes=$(df -P --block-size=1 "$TARGET_HOME" 2>/dev/null | awk 'NR==2{print $4}')
  printf '\n' >&3
  info "Archive size            : $(hsize "$arch_bytes")"
  info "Estimated extracted size: ~$(hsize "$est_bytes")"
  [ -n "$free_bytes" ] && info "Free space in your home : $(hsize "$free_bytes")"
  local need=0 why=""
  if [ -n "$free_bytes" ] && awk -v f="$free_bytes" -v e="$est_bytes" 'BEGIN{exit !(f < e*2)}'; then need=1; why="free space in your home may be insufficient"; fi
  if awk -v e="$est_bytes" 'BEGIN{exit !(e > 50*1024*1024*1024)}'; then need=1; why="${why:+$why and }the restore exceeds 50 GB"; fi
  if [ "$need" = 1 ]; then
    printf '  You are being asked to confirm because %s. Continue? (y/n): ' "$why" > /dev/tty
    read -r ans < /dev/tty || ans="n"; case "$ans" in [Yy]*) ;; *) info "Restore cancelled."; return 0 ;; esac
  fi

  # ---- Prompt 2: deviated/quarantine path (created if missing) ----
  printf '\n' >&3
  info "Some application data cannot be safely placed on its Linux path automatically. That data"
  info "goes to a DEVIATED directory you pick, so you can review and promote it by hand."
  local quar
  while :; do
    printf "  Deviated/restore directory for un-promotable data ('restore path'/s=skip): " > /dev/tty
    read -r ans < /dev/tty || ans="skip"
    case "$ans" in
      [Ss]|[Ss][Kk][Ii][Pp]) quar="$TARGET_HOME/MigrateToLinux_restored"; info "Using default deviated dir: $quar"; break ;;
      *) quar="$(resolve_user_path "$ans")"; [ -n "$quar" ] && break; err "  Enter a valid path, or 's' for the default." ;;
    esac
  done
  mkdir -p "$quar" 2>/dev/null || { quar="$TARGET_HOME/MigrateToLinux_restored"; mkdir -p "$quar"; }

  # ---- Extract to a temp dir ----
  printf '\n' >&3
  log "Extracting the archive (this may take a while) ..."
  local tmp; tmp="$(mktemp -d)"
  local ok_extract=1
  if is_dry_run; then
    info "[dry-run] would extract $arch"
  elif [ "$encrypted" = 1 ]; then
    openssl enc -d -aes-256-cbc -pbkdf2 -salt -pass pass:"$MIGRATE_XFER_PWD" -in "$arch" 2>/dev/null \
      | tar -xzf - -C "$tmp" 2>/dev/null || ok_extract=0
  else
    tar -xzf "$arch" -C "$tmp" 2>/dev/null || ok_extract=0
  fi
  if [ "$ok_extract" != 1 ]; then
    err "Could not extract the archive (wrong password, or it is corrupt/not a Migrate-to-Linux backup)."
    rm -rf "$tmp" 2>/dev/null || true
    mark_fail "data restore" "archive could not be extracted"
    return 0
  fi

  # ---- 1. Static profile data -> home ----
  if [ -d "$tmp/user" ]; then
    place_tree "$tmp/user" "$TARGET_HOME"
    mark_ok "profile data" "restored into $TARGET_HOME"
  fi

  # ---- 2. Application data per scope ----
  local promoted=0 quarantined=0
  if [ -d "$tmp/apps" ]; then
    local slug appdir sdir matchkey
    for appdir in "$tmp/apps"/*/; do
      [ -d "$appdir" ] || continue
      slug="$(basename "$appdir")"
      for scope in userdir system; do
        sdir="$appdir$scope"
        [ -d "$sdir" ] || continue
        # Map this staged slug back to a manifest app key (slug shared with the ps1 side).
        matchkey="$(jq -r --arg sl "$slug" '
          .applications | to_entries[]
          | select((.key|ascii_downcase|gsub(" ";"-")|gsub("[^a-z0-9_-]";"")) == $sl) | .key' "$DM" 2>/dev/null | head -n1)"
        if [ -z "$matchkey" ]; then place_tree "$sdir" "$quar/$slug/$scope"; quarantined=$((quarantined+1)); continue; fi
        tgt="$(jq -r --arg k "$matchkey" --arg s "$scope" '.applications[$k][$s].linuxTarget // ""' "$DM" 2>/dev/null)"
        safe="$(jq -r --arg k "$matchkey" --arg s "$scope" '.applications[$k][$s].userdir_safe_to_transfer_to_corresponding_paths_for_linux // .applications[$k][$s].safe_to_transfer_to_corresponding_paths_for_linux // "no"' "$DM" 2>/dev/null)"
        local promote=0 rewrite=0
        case "$safe" in
          yes)               promote=1 ;;
          yes-after-rewrite) promote=1; rewrite=1 ;;
          "same version")    [ "$MIGRATE_VERSION_MODE" = same ] && promote=1 ;;
          *)                 promote=0 ;;
        esac
        if [ "$promote" = 1 ] && [ -n "$tgt" ]; then
          local dest rwnote=""; dest="$(resolve_target "$tgt")"
          if [ "$rewrite" = 1 ]; then apply_rewrites "$matchkey" "$scope" "$sdir"; rwnote=" (paths rewritten; .bak kept)"; fi
          place_tree "$sdir" "$dest"
          mark_ok "$matchkey [$scope]" "promoted to $dest$rwnote"
          promoted=$((promoted+1))
        else
          place_tree "$sdir" "$quar/$slug/$scope"
          quarantined=$((quarantined+1))
        fi
      done
    done
  fi
  fix_owner "$quar"
  rm -rf "$tmp" 2>/dev/null || true

  # ---- Closing report: deviated dir + manual-promote warning ----
  printf '\n' >&3
  ok "Data restore finished: $promoted scope(s) promoted to their Linux paths, $quarantined left in the deviated directory."
  if [ "$quarantined" -gt 0 ]; then
    warn "Some data was placed in the DEVIATED directory: $quar"
    warn "It was NOT promoted automatically because it is not known to be safe on its Linux path."
    warn "You may promote it by hand AT YOUR OWN RISK -- and TEST the affected application afterwards."
  fi
  if [ "$promoted" -gt 0 ]; then
    warn "Promoted data was placed on live application paths. A correct copy/rewrite does not guarantee the"
    warn "app accepts it -- please OPEN and TEST each affected application; restore a .bak if anything misbehaves."
  fi
}

restore_main "$@"
